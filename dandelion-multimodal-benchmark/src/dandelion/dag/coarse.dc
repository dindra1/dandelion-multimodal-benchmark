function ingress (request) => (text_data, audio_data, image_data);
function coarse_text (raw_text) => (result);
composition coarse_text_pipeline (req) => (out) {
    ingress (request = all req) => (text_out = text_data, audio_out = audio_data, img_out = image_data);
    coarse_text (raw_text = all text_out) => (out = result);
}
